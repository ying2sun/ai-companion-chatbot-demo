# Copy this file to .env and fill in real values.
# .env itself is gitignored, never commit real keys.

GEMINI_API_KEY=
GROQ_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Only needed to run backend/eval/judge.py and validate_judge.py.
# Never read by the deployed /chat backend itself, so it doesn't need
# to be set on Render, local only.
ANTHROPIC_API_KEY=

# Only needed to run backend/eval/label_with_models.py, cross-checks
# the gold set's own labels using GPT-4o and DeepSeek V3. Also local
# only, never read by the deployed backend.
OPENROUTER_API_KEY=

# Optional. Global daily cap on /chat calls across all sessions combined.
# Defaults to 300 if unset, see backend/core/limiter.py.
DAILY_CHAT_LIMIT=300
